---
import PopoverMock from '../components/PopoverMock.astro';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>AirflowBar — Airflow in your menu bar</title>
  <meta name="description" content="Airflow DAG monitoring from your macOS menu bar. Failures, status, health — always visible, never in the way." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --sans: 'Urbanist', sans-serif; --mono: 'Space Mono', monospace; }
    html, body { height: 100%; }
    body { background: #060a0f; font-family: var(--sans); display: flex; align-items: center; justify-content: center; -webkit-font-smoothing: antialiased; min-height: 100vh; }
    canvas#radar { position: fixed; inset: 0; z-index: 0; width: 100%; height: 100%; }
    .scene { position: relative; z-index: 1; display: flex; align-items: center; gap: clamp(3rem, 6vw, 7rem); padding: 2rem; }
    .info { animation: fadeSlide 0.8s ease both; }
    .wordmark { font-size: 1.6rem; font-weight: 600; color: #f4f4f5; letter-spacing: -0.03em; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.6rem; }
    .wordmark .dot { width: 10px; height: 10px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,0.6); animation: pulse 2s ease-in-out infinite; }
    .tagline { font-size: 0.95rem; font-weight: 300; color: #a1a1aa; line-height: 1.65; margin-bottom: 2rem; white-space: nowrap; }
    .actions { display: flex; gap: 0.75rem; margin-bottom: 2.5rem; }
    .btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1.2rem; border-radius: 8px; font-family: var(--sans); font-size: 0.8rem; font-weight: 500; text-decoration: none; transition: all 0.2s; }
    .btn-primary { background: #f4f4f5; color: #09090b; }
    .btn-primary:hover { background: #fff; box-shadow: 0 0 20px rgba(244,244,245,0.15); }
    .btn-ghost { background: rgba(34,197,94,0.06); color: #a1a1aa; border: 1px solid rgba(34,197,94,0.1); }
    .btn-ghost:hover { background: rgba(34,197,94,0.12); color: #f4f4f5; }
    .meta { display: flex; gap: 1.5rem; font-size: 0.7rem; color: #52525b; font-family: var(--mono); }
    .meta a { color: #52525b; text-decoration: none; transition: color 0.2s; }
    .meta a:hover { color: #a1a1aa; }
    .popover-wrap { animation: popIn 0.6s ease 0.2s both; }
    @keyframes fadeSlide { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
    @keyframes popIn { from { opacity: 0; transform: translateY(12px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(0.85); } }
    @media (max-width: 800px) {
      .scene { flex-direction: column; gap: 2rem; padding: 4rem 1.5rem; } .info { text-align: center; }
      .tagline { white-space: normal; }
      .actions { justify-content: center; } .meta { justify-content: center; }
      body { overflow-y: auto; height: auto; } html { height: auto; }
    }
  </style>
</head>
<body>
  <canvas id="radar"></canvas>
  <div class="scene">
    <div class="info">
      <div class="wordmark"><span class="dot"></span>AirflowBar</div>
      <p class="tagline">Airflow DAG monitoring from your macOS menu bar.<br/>Failures, status, health — always visible, never in the way.</p>
      <div class="actions">
        <a class="btn btn-primary" href="https://github.com/maroil/airflow-bar/releases/latest">Download</a>
        <a class="btn btn-ghost" href="https://github.com/maroil/airflow-bar" target="_blank" rel="noopener">GitHub</a>
      </div>
      <div class="meta"><span>macOS 14+</span><span>Native Swift</span><a href="https://github.com/maroil/airflow-bar/blob/main/LICENSE">MIT</a></div>
    </div>
    <div class="popover-wrap"><PopoverMock /></div>
  </div>
  <script>
    const canvas = document.getElementById('radar');
    const ctx = canvas.getContext('2d');
    let W, H, cx, cy, maxR, angle = 0;
    const blips = [];
    const BLIP_COLORS = ['#22c55e','#22c55e','#22c55e','#3b82f6','#ef4444','#f59e0b'];
    function resize() { W=canvas.width=window.innerWidth; H=canvas.height=window.innerHeight; cx=W*0.5; cy=H*0.5; maxR=Math.max(W,H)*0.6; }
    function spawnBlips() {
      blips.length = 0;
      for (let i=0;i<20;i++) blips.push({ angle:Math.random()*Math.PI*2, radius:60+Math.random()*(maxR-80),
        color:BLIP_COLORS[Math.floor(Math.random()*BLIP_COLORS.length)], size:2+Math.random()*2.5, opacity:0, fadeSpeed:0.002+Math.random()*0.003 });
    }
    function draw() {
      ctx.clearRect(0,0,W,H); angle += 0.008;
      for(let i=1;i<=6;i++){const r=(maxR/6)*i;ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.strokeStyle='rgba(34,197,94,0.04)';ctx.lineWidth=1;ctx.stroke();}
      ctx.strokeStyle='rgba(34,197,94,0.03)';ctx.beginPath();ctx.moveTo(cx-maxR,cy);ctx.lineTo(cx+maxR,cy);ctx.moveTo(cx,cy-maxR);ctx.lineTo(cx,cy+maxR);ctx.stroke();
      const grad=ctx.createConicGradient(angle,cx,cy);grad.addColorStop(0,'rgba(34,197,94,0.12)');grad.addColorStop(0.6/(Math.PI*2),'rgba(34,197,94,0)');grad.addColorStop(1,'rgba(34,197,94,0)');
      ctx.beginPath();ctx.arc(cx,cy,maxR,0,Math.PI*2);ctx.fillStyle=grad;ctx.fill();
      const lx=cx+Math.cos(angle)*maxR,ly=cy+Math.sin(angle)*maxR;ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(lx,ly);ctx.strokeStyle='rgba(34,197,94,0.2)';ctx.lineWidth=1.5;ctx.stroke();
      for(const blip of blips){
        let ad=((angle%(Math.PI*2))-blip.angle+Math.PI*2)%(Math.PI*2);if(ad<0.1&&ad>0)blip.opacity=1;
        blip.opacity=Math.max(0,blip.opacity-blip.fadeSpeed);
        if(blip.opacity>0){const bx=cx+Math.cos(blip.angle)*blip.radius,by=cy+Math.sin(blip.angle)*blip.radius;
          ctx.beginPath();ctx.arc(bx,by,blip.size*5,0,Math.PI*2);ctx.fillStyle=blip.color;ctx.globalAlpha=blip.opacity*0.1;ctx.fill();
          ctx.beginPath();ctx.arc(bx,by,blip.size,0,Math.PI*2);ctx.fillStyle=blip.color;ctx.globalAlpha=blip.opacity*0.8;ctx.fill();ctx.globalAlpha=1;}
      }
      ctx.beginPath();ctx.arc(cx,cy,3,0,Math.PI*2);ctx.fillStyle='rgba(34,197,94,0.3)';ctx.fill();
      requestAnimationFrame(draw);
    }
    resize();spawnBlips();draw();
    window.addEventListener('resize',()=>{resize();spawnBlips();});
  </script>
</body>
</html>
